# Copy this file to .env.local and fill in your credentials.
# Never commit .env.local to git.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — console.anthropic.com > API Keys (server-side only, no NEXT_PUBLIC_ prefix)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# PostHog — Project Settings > API Keys
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
